generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  VIEWER
}

enum QuizType {
  QUIZ
  POLL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  telegramId  String?  @unique
  firstName   String
  lastName    String?
  username    String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships  GroupMember[]
  sentQuizzes  Quiz[]
  credential   InstructorCredential?
  createdExams Exam[]

  @@map("users")
}

model InstructorCredential {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("instructor_credentials")
}

model Group {
  id           String   @id @default(cuid())
  chatId       String   @unique
  title        String
  username     String?
  photoUrl     String?
  isForum      Boolean  @default(false)
  memberCount  Int?
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  members     GroupMember[]
  quizzes     Quiz[]
  topics      Topic[]
  botConfig   BotConfig?
  exams       Exam[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  role      Role     @default(ADMIN)
  approved  Boolean  @default(true)
  joinedAt  DateTime @default(now())

  userId   String
  groupId  String

  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

model Quiz {
  id               String    @id @default(cuid())
  question         String
  options          String[]
  correctOptionId  Int?
  explanation      String?
  type             QuizType  @default(QUIZ)
  isAnonymous      Boolean   @default(true)
  allowsMultiple   Boolean   @default(false)
  openPeriod       Int?
  topicId          Int?
  topicName        String?
  mediaUrl         String?   // optional image attached before the poll
  scheduledAt      DateTime?
  recurrence       String?   // "daily" | "weekly" | "biweekly" | "monthly" | null
  sentAt           DateTime?
  deletedAt        DateTime? // set when manually deleted from Telegram
  pollClosed       Boolean   @default(false) // set when Telegram poll is stopped
  messageId        Int?
  pollId           String?
  tags             String[]  @default([])
  allowAddingOptions Boolean @default(false)
  allowRevoting      Boolean @default(false)
  createdAt        DateTime  @default(now())

  groupId   String
  sentById  String

  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sentBy   User   @relation(fields: [sentById], references: [id])
  answers  PollAnswer[]

  @@map("quizzes")
}


model PollAnswer {
  id          String   @id @default(cuid())
  optionIds   Int[]
  answeredAt  DateTime @default(now())

  quizId          String
  telegramUserId  String
  firstName       String?
  username        String?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, telegramUserId])
  @@map("poll_answers")
}

model Topic {
  id                String  @id @default(cuid())
  topicId           Int
  name              String
  iconColor         Int?
  iconCustomEmojiId String?
  isClosed          Boolean @default(false)

  groupId String

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, topicId])
  @@map("topics")
}

model BotConfig {
  id                 String  @id @default(cuid())
  webhookSecret      String  @default(cuid())
  defaultAnonymous   Boolean @default(true)
  defaultOpenPeriod  Int     @default(0)
  defaultType        QuizType @default(QUIZ)
  allowMultiple      Boolean @default(false)
  updatedAt          DateTime @updatedAt

  groupId String @unique

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

model Exam {
  id           String   @id @default(cuid())
  title        String
  description  String?
  questions    Json     // Array<{ question, options, correctOptionId, explanation }>
  timeLimit    Int?     // seconds; null = no limit
  passingScore Int      @default(60) // percentage
  isPublished  Boolean  @default(false)
  launchMsgId  Int?     // Telegram message_id of the launch announcement
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupId     String
  createdById String

  group     Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])
  results   ExamResult[]

  @@map("exams")
}

model ExamResult {
  id          String   @id @default(cuid())
  name        String
  telegramId  String?
  answers     Json     // { [questionIndex]: selectedOptionId }
  score       Int      // percentage 0-100
  passed      Boolean
  duration    Int?     // seconds taken
  completedAt DateTime @default(now())

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_results")
}
