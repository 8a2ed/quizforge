# Environment Variables — QuizForge
# Copy this file to .env.local and fill in all values

# ─── Database ─────────────────────────────────────────────────────────────────
# Get a free PostgreSQL URL from https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/quizforge?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-64-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="8746720835:AAFnVkmQGQnv_DkjL6Tc7bIDz9Gzt2QaVVE"
NEXT_PUBLIC_BOT_USERNAME="agridmu_bot"

# ─── Webhook ──────────────────────────────────────────────────────────────────
# The public URL where Telegram will POST poll_answer updates
# For local dev, use ngrok: ngrok http 3000
WEBHOOK_BASE_URL="https://your-domain.com"

# ─── Azure (Production) ───────────────────────────────────────────────────────
AZURE_APP_NAME="quizforge"
AZURE_RESOURCE_GROUP="quizforge-rg"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="QuizForge"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
